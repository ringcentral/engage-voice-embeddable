{
  "appVersion": "1.0.0-beta",
  "distPath": "dist",
  "buildPath": "build",
  "themePath": "./next",
  "pages": [
    {
      "index": "next/app.html",
      "main": "next/app.ts"
    },
    {
      "main": "next/adapter.ts",
      "filename": "adapter.js"
    },
    {
      "index": "next/redirect.html",
      "main": "next/redirect.ts"
    }
  ],
  "assets": [
    { "from": "next/favicon.ico", "to": "favicon.ico" },
    { "from": "next/icon.svg", "to": "icon.svg" },
    { "from": "next/popup.html", "to": "popup.html" },
    { "from": "next/index.html", "to": "index.html" },
    { "from": "next/agentLibrary.js", "to": "agentLibrary.js" },
    { "from": "next/assets/ringCXLogo.svg", "to": "assets/ringCXLogo.svg" },
    { "from": "next/assets/logo.svg", "to": "assets/logo.svg" },
    { "from": "next/assets/popup.svg", "to": "assets/popup.svg" }
  ],
  "environment": {
    "local": {
      "brand": ["rc"],
      "mode": "development"
    },
    "dev": {
      "brand": ["rc"],
      "mode": "production"
    },
    "prod": {
      "brand": ["rc"],
      "mode": "production"
    }
  },
  "appConfigPath": "config/index.ts",
  "devServerPort": 8080,
  "themeSystem": "spring-ui"
}
